---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { Content, getHeadings } from "../../nokkvi/changelog-archive/CHANGELOG-0.4.md";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<StarlightPage
  frontmatter={{ title: "Changelog — v0.4.x archive" }}
  hasSidebar={false}
  headings={getHeadings()}
>
  <p>
    <a href={`${base}/changelog/`}>← Back to current changelog</a>
  </p>
  <Content />
</StarlightPage>

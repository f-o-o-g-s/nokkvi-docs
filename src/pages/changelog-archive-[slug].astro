---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

export async function getStaticPaths() {
  const modules = import.meta.glob("../../nokkvi/changelog-archive/CHANGELOG-*.md", {
    eager: true,
  });
  return Object.entries(modules).flatMap(([path, mod]) => {
    const m = path.match(/CHANGELOG-(\d+)\.(\d+)\.md$/);
    if (!m) return [];
    return [
      {
        params: { slug: `${m[1]}-${m[2]}` },
        props: { mod, version: `v${m[1]}.${m[2]}.x` },
      },
    ];
  });
}

const { mod, version } = Astro.props;
const { Content, getHeadings } = mod;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<StarlightPage
  frontmatter={{ title: `Changelog — ${version} archive` }}
  hasSidebar={false}
  headings={getHeadings()}
>
  <p>
    <a href={`${base}/changelog/`}>← Back to current changelog</a>
  </p>
  <Content />
</StarlightPage>
